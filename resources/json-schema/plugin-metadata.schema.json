{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://3dcitydb.org/citydb-tool/json-schema/@major@.@minor@/plugin-metadata.schema.json",
  "title": "Plugin metadata schema",
  "description": "JSON schema for the metadata of plugins.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name"
  ],
  "properties": {
    "name": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+.*$"
    },
    "url": {
      "type": "string"
    },
    "description": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "vendor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "url": {
          "type": "string"
        }
      }
    },
    "startEnabled": {
      "type": "boolean",
      "default": true
    }
  }
}